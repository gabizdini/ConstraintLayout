<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/purple_primary"
        android:text="Constraint Layouts"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnBlog"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:text="BLOG POST"
        android:backgroundTint="@color/purple_primary"
        android:textColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/txtTitulo"
        app:layout_constraintBottom_toTopOf="@id/btnSerie"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="100dp"/>

    <Button
        android:id="@+id/btnSerie"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:text="SÉRIE"
        android:backgroundTint="@color/purple_primary"
        android:textColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/btnBlog"
        app:layout_constraintBottom_toTopOf="@id/btnConcurso"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="90dp"/>

    <Button
        android:id="@+id/btnConcurso"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:text="CONCURSO DE TEXTOS"
        android:backgroundTint="@color/purple_primary"
        android:textColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/btnSerie"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="90dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>