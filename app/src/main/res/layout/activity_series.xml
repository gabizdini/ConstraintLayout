<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Top bar -->
    <TextView
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@color/purple_primary"
        android:text="Netflix"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Botão Voltar -->
    <Button
        android:id="@+id/btnVoltar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VOLTAR"
        android:backgroundTint="@color/purple_primary"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toTopOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="@id/topBar"
        app:layout_constraintEnd_toEndOf="@id/topBar"
        android:layout_marginEnd="8dp"/>

    <!-- Series title with drawable below (arrow) -->
    <TextView
        android:id="@+id/tvSeriesTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Heartland"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:drawableBottomCompat="@drawable/ic_arrow_down"/>

    <!-- Episode label -->
    <TextView
        android:id="@+id/tvEpisode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="S1 • E08"
        android:textColor="#000000"
        android:textSize="12sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvSeriesTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Poster image -->
    <ImageView
        android:id="@+id/imgPoster"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:scaleType="centerCrop"
        android:src="@drawable/serie"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvEpisode"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- SeekBar -->
    <SeekBar
        android:id="@+id/seekBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:progress="20"
        android:max="100"
        android:thumbTint="@color/purple_primary"
        android:progressTint="@color/purple_primary"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/imgPoster"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"/>

    <!-- Time labels -->
    <TextView
        android:id="@+id/tvTimeStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="20:00"
        android:textColor="#000000"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/seekBar"
        app:layout_constraintStart_toStartOf="@id/seekBar"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tvTimeEnd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="40:00"
        android:textColor="#000000"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/seekBar"
        app:layout_constraintEnd_toEndOf="@id/seekBar"
        android:layout_marginTop="8dp"/>

    <!-- Controls: replay, play, cast -->
    <ImageView
        android:id="@+id/ivReplay"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_replay"
        android:contentDescription="replay"
        app:tint="#000000"
        app:layout_constraintTop_toBottomOf="@id/tvTimeStart"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/ivPlay"
        android:layout_marginTop="24dp"
        android:layout_marginStart="32dp"/>

    <ImageView
        android:id="@+id/ivPlay"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_play"
        android:contentDescription="play"
        app:tint="#000000"
        app:layout_constraintTop_toBottomOf="@id/tvTimeStart"
        app:layout_constraintStart_toEndOf="@id/ivReplay"
        app:layout_constraintEnd_toStartOf="@id/ivCast"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"/>

    <ImageView
        android:id="@+id/ivCast"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_cast"
        android:contentDescription="cast"
        app:tint="#000000"
        app:layout_constraintTop_toBottomOf="@id/tvTimeStart"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="32dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>

